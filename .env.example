# BlockVerify Environment Configuration
# Copy this file to .env and fill in your values

# ── Blockchain ──────────────────────────────
# URL of your Ganache instance
GANACHE_URL=http://127.0.0.1:7545

# Contract address after running: python contracts/deploy.py
# Leave blank to run in mock mode (no Ganache required)
CONTRACT_ADDRESS=

# ── Server ──────────────────────────────────
PORT=5000

# ── Email Alerts (optional) ─────────────────
# Gmail App Password recommended (NOT your regular password)
# Enable at: https://myaccount.google.com/apppasswords
ALERT_EMAIL_USER=your_email@gmail.com
ALERT_EMAIL_PASS=your_gmail_app_password_here
ALERT_EMAIL=recipient@example.com

# ── Security ────────────────────────────────
# Generate a new AES key by running:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_AES_KEY=your_generated_fernet_key_here

# ── Database ────────────────────────────────
# Default: blockverify.db in the backend folder
# DB_PATH=./blockverify.db
